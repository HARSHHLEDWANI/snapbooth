# ─────────────────────────────────────────────────────────────
# snapbooth — environment variables
# Copy this file to `.env.local` and fill in your own values.
# All are client-side (NEXT_PUBLIC_*) — there is no server/backend.
# ─────────────────────────────────────────────────────────────

# EmailJS (https://dashboard.emailjs.com) — used by the "email me my strip" feature.
# 1. Create a Service (e.g. Gmail) -> gives you a SERVICE ID.
# 2. Create an Email Template (see variables below) -> gives you a TEMPLATE ID.
# 3. Account -> API Keys -> PUBLIC KEY.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx

# Optional: override the destination address shown in the UI copy.
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com
